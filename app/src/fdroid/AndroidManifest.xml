<?xml version="1.0" encoding="utf-8"?>
<!--
  F-Droid / FOSS build: explicitly strip network and ad permissions.
  The store flavor adds these in src/store/AndroidManifest.xml; this file
  ensures they never appear in fdroid APKs even if a dependency tries to merge them in.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.INTERNET"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:node="remove" />
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />

</manifest>
